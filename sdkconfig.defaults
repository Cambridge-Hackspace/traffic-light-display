# cpu config
CONFIG_ESP_DEFAULT_CPU_FREQ_MHZ_240=y
CONFIG_ESP_DEFAULT_CPU_FREQ_MHZ=240
CONFIG_ESP_SYSTEM_EVENT_TASK_PINNED_TO_CORE_0=y  # make sure wifi is pinned to core 0,
CONFIG_ESP_WIFI_TASK_PINNED_TO_CORE_0=y          # keeping it separate from display thread

# timing config
CONFIG_FREERTOS_HZ=1000

# stack config
CONFIG_ESP_MAIN_TASK_STACK_SIZE=8192
CONFIG_ESP_SYSTEM_EVENT_TASK_STACK_SIZE=4096
CONFIG_FREERTOS_IDLE_TASK_STACKSIZE=4096
CONFIG_PTHREAD_TASK_STACK_SIZE_DEFAULT=4096

# iram config
CONFIG_ESP_WIFI_IRAM_OPT=y      # prevent wifi from locking
CONFIG_ESP_WIFI_RX_IRAM_OPT=y   # up the flash memory, which
CONFIG_RMT_ISR_IRAM_SAFE=y      # may bork the display

# http config
CONFIG_HTTPD_MAX_REQ_HDR_LEN=1024
CONFIG_HTTPD_MAX_URI_LEN=1024
