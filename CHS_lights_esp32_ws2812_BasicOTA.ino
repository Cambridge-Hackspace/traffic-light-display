void led_test(int count)
{
    for (int n=0;n<count;n++)
    {
      //strip.setPixelColor(n, 1,1,1);
      strip.setLedColorData(n, 0xffffff);
    }
    strip.show();
    delay(1000);
}

// The leds are arranged in a S shaped path instead of a standard matrix with rows. This flips the index bits to the S path
int unloop(int k)
{
  // 0-7 15-8 16-
  if (k&8)
    return(k^7);
  return k;
}

int loop_counter = 0;

void loop() {
  if (scroll_count == 0)
    Serial.println("Text loop");
  // Some example procedures showing how to display to the pixels:
  /*colorWipe(strip.Color(1, 1, 1), 150); // Red
  colorWipe(strip.Color(0, 1, 0), 50); // Green
  colorWipe(strip.Color(0, 0, 1), 50); // Blue
  */

  char text[] = "    Cambridge HACKSPACE!    ";
  text[0] = 1;
  text[2] = 1;
  int textlen = sizeof(text)-4;
  scroll_count ++;

  //const int dir = -1;
  const int horizontal = 1;
  const int xdir = -1; // flip x with 1/-1
  const int ydir = -1; // flip y with 1/-1
  for (int k=1;k<192; k++)
  {
    int x=(192+k*xdir)/8+scroll_count;
    if (k>=64)
      x+=7*xdir;
    if (k>=128)
      x+=7*xdir;
    int y=(7-k*ydir)&7;
    int ch = text[(x/8)%textlen];
    
    // row and bit for vertical text
    int r = (x)&7;
    int b = y&7;
    
    int i;
    if (horizontal==1) i = ((font[ch][b]>>r)&1)*25; //scrolling long way 
    else i = ((font[ch][r]>>b)&1)*5;  //vertical
    
    //strip.setPixelColor(unloop(k)-1+8, i,i,i);
    strip.setLedColorData(unloop(k)-1+8, (i>0)*0xffffff);
  }
  
  // Blinky time counter on the 8 led strip before the sign
  int b = loop_counter;
  for(int k=0;k<8;k++)
  {
    //strip.setPixelColor(k, counter&(1<<k), 0, 0);
     strip.setLedColorData(k, (b&1)*0xffffff);
     b>>=1;
  }
  loop_counter++;
  if (scroll_count>=8*textlen)
    scroll_count -= 8*textlen;
  strip.show();
  delay(66);

